# ═══════════════════════════════════════════════════
#  WebLaunch Environment Configuration
# ═══════════════════════════════════════════════════

# Application
NODE_ENV=production
API_KEY=                        # Leave empty to disable auth in dev

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=4000
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Redis
REDIS_PASSWORD=                 # Set a strong password in production

# Kubernetes
K8S_NAMESPACE=weblaunch

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123 # Change this in production

# Logging
LOG_LEVEL=info
