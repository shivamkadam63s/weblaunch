{
  "title": "WebLaunch Overview",
  "uid": "weblaunch-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Backend Status",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "up{job=\"weblaunch-backend\"}", "refId": "A" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 2, "type": "gauge", "title": "CPU Usage %",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "id": 3, "type": "gauge", "title": "Memory Usage %",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "targets": [{ "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 4, "type": "timeseries", "title": "CPU Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [{ "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU - {{instance}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Memory Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [{ "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024", "legendFormat": "Memory MB", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "megabytes" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Container CPU",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total{name=~\"weblaunch.*\"}[2m]) * 100", "legendFormat": "{{name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Container Memory",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [{ "expr": "container_memory_usage_bytes{name=~\"weblaunch.*\"} / 1024 / 1024", "legendFormat": "{{name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "megabytes" } }
    }
  ]
}
