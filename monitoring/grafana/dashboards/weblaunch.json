{
  "title": "🖥️ Server Overview",
  "uid": "weblaunch-overview-v5",
  "description": "Premium Monitoring with Deployed App Focus",
  "version": 5,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["weblaunch", "server"],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🚀 Deployed Applications (K8s)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Website CPU Usage",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (id) (rate(container_cpu_usage_seconds_total{id=~\".*kubepods/(besteffort|burstable)/pod.*/.*\"}[2m])) * 100",
        "legendFormat": "App: {{id}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "overrides": [
            {
              "matcher": { "id": "byRegexp", "options": "/.*/pod([^/]+)/([^/]+)/" },
              "properties": [{ "id": "displayName", "value": "Website $1" }]
            }
          ]
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*/pod([a-f0-9-]{8})[^/]*/([a-f0-9]{8})[a-f0-9]+",
            "renamePattern": "App [$1...$2]"
          }
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "lastNotNull"] } }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Website RAM Usage",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [{
        "expr": "container_memory_usage_bytes{id=~\".*kubepods/(besteffort|burstable)/pod.*/.*\"} / 1024 / 1024",
        "legendFormat": "App: {{id}}"
      }],
      "fieldConfig": { "defaults": { "unit": "megabytes", "custom": { "fillOpacity": 15, "lineWidth": 2 } } },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*/pod([a-f0-9-]{8})[^/]*/([a-f0-9]{8})[a-f0-9]+",
            "renamePattern": "App [$1...$2]"
          }
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "lastNotNull"] } }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Website Network I/O",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (id) (rate(container_network_receive_bytes_total{id=~\".*kubepods/(besteffort|burstable)/pod.*/.*\"}[2m]))",
          "legendFormat": "Inbound {{id}}"
        },
        {
          "expr": "sum by (id) (rate(container_network_transmit_bytes_total{id=~\".*kubepods/(besteffort|burstable)/pod.*/.*\"}[2m]))",
          "legendFormat": "Outbound {{id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 1.5 } } },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "(Inbound|Outbound) .*/pod([a-f0-9-]{8})[^/]*/([a-f0-9]{8})[a-f0-9]+",
            "renamePattern": "$1 [$1...$2]"
          }
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Website Disk I/O",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (id) (rate(container_fs_reads_bytes_total{id=~\".*kubepods/(besteffort|burstable)/pod.*/.*\"}[2m]))",
          "legendFormat": "Read {{id}}"
        },
        {
          "expr": "sum by (id) (rate(container_fs_writes_bytes_total{id=~\".*kubepods/(besteffort|burstable)/pod.*/.*\"}[2m]))",
          "legendFormat": "Write {{id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 1.5 } } },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "(Read|Write) .*/pod([a-f0-9-]{8})[^/]*/([a-f0-9]{8})[a-f0-9]+",
            "renamePattern": "$1 [$1...$2]"
          }
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "⚙️ Infrastructure & Host",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 },
      "collapsed": true
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Host CPU",
      "gridPos": { "x": 0, "y": 17, "w": 4, "h": 5 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Host RAM",
      "gridPos": { "x": 4, "y": 17, "w": 4, "h": 5 },
      "targets": [{ "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    }
  ]
}
