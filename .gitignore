# ═══════════════════════════════════════
#  WebLaunch .gitignore
# ═══════════════════════════════════════

# ── Environment & Secrets ──────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.cert
secrets/
vault/

# ── Node.js ────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-lock.yaml
.npm

# ── Build Outputs ──────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
*.egg-info/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
target/
*.class
*.jar
*.war

# ── Logs ───────────────────────────────
logs/
*.log
npm-debug.log*

# ── Docker ─────────────────────────────
.docker/

# ── Terraform ──────────────────────────
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log
crash.*.log

# ── Ansible ────────────────────────────
*.retry
ansible/inventory/hosts_local.yml
ansible/vault_pass.txt

# ── IDE / Editor ───────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.directory

# ── OS ─────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini

# ── Testing ────────────────────────────
coverage/
.nyc_output/
junit.xml

# ── Temporary ──────────────────────────
tmp/
temp/
.cache/
*.tmp
*.bak
*.orig

# ── K8s ────────────────────────────────
kubeconfig
*.kubeconfig
kube-config

# ── Monitoring data ────────────────────
monitoring/grafana/data/
monitoring/prometheus/data/
